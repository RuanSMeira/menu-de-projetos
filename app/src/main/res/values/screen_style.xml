<resources>
    <style name="BaseScreenResultado">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:padding">24dp</item>
    </style>

    <style name="ScreenMagreza" parent="BaseScreenResultado"><item name="android:background">#B71C1C</item></style>
    <style name="ScreenNormal" parent="BaseScreenResultado"><item name="android:background">#4CAF50</item></style>
    <style name="ScreenSobrepeso" parent="BaseScreenResultado"><item name="android:background">#FFEB3B</item></style>
    <style name="ScreenObeso1" parent="BaseScreenResultado"><item name="android:background">#FFC107</item></style>
    <style name="ScreenObeso2" parent="BaseScreenResultado"><item name="android:background">#FF9800</item></style>
    <style name="ScreenObeso3" parent="BaseScreenResultado"><item name="android:background">#F44336</item></style>

    <style name="TextoResultadoBase">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextoResultadoMagreza" parent="TextoResultadoBase">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextoResultadoNormal" parent="TextoResultadoBase">
        <item name="android:textColor">#1B5E20</item> </style>

    <style name="TextoResultadoSobrepeso" parent="TextoResultadoBase">
        <item name="android:textColor">#E65100</item> </style>

    <style name="TextoResultadoObeso1" parent="TextoResultadoBase">
        <item name="android:textColor">#BF360C</item> </style>

    <style name="TextoResultadoObeso2" parent="TextoResultadoBase">
        <item name="android:textColor">@color/white</item> </style>

    <style name="TextoResultadoObeso3" parent="TextoResultadoBase">
        <item name="android:textColor">@color/white</item> </style>
</resources>